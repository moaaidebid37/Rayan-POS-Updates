<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تسجيل الدخول - Solo System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=Cairo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="css/style.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Poppins', 'Cairo', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fafafa;
            padding: var(--spacing-lg);
            position: relative;
        }
        
        .login-card {
            background: #ffffff;
            border: 1px solid #e8e8e8;
            border-radius: 16px;
            padding: 56px 48px;
            width: 100%;
            max-width: 480px;
            position: relative;
            z-index: 1;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }
        
        .login-logo {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .logo-badge {
            display: inline-block;
            background: #000000;
            color: white;
            padding: 10px 24px;
            border-radius: 24px;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 1px;
            margin-bottom: 20px;
            text-transform: uppercase;
        }
        
        .login-logo h1 {
            color: #000000;
            font-size: 42px;
            margin-bottom: 12px;
            font-weight: 800;
            letter-spacing: -1px;
            line-height: 1.2;
        }
        
        .login-logo h1 .logo-highlight {
            color: #000000;
        }
        
        .login-logo p {
            color: #666666;
            font-size: 15px;
            margin: 0;
            line-height: 1.6;
            font-weight: 400;
        }
        
        .login-form {
            margin-top: var(--spacing-xl);
        }
        
        .form-group {
            margin-bottom: var(--spacing-lg);
            position: relative;
        }
        
        .form-group label {
            display: block;
            color: #000000;
            margin-bottom: 10px;
            font-weight: 600;
            font-size: 14px;
            letter-spacing: 0.2px;
        }
        
        .input-wrapper {
            position: relative;
        }
        
        .input-wrapper i {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.4);
            transition: all 0.3s ease;
        }
        
        .input {
            width: 100%;
            padding: 16px 48px 16px 18px;
            background: #fafafa;
            border: 2px solid #e8e8e8;
            border-radius: 14px;
            color: #000000;
            font-size: 15px;
            font-weight: 500;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-family: inherit;
        }
        
        .input::placeholder {
            color: #999999;
            font-weight: 400;
        }
        
        .input:focus {
            outline: none;
            border-color: #000000;
            background: #ffffff;
        }
        
        .input:focus + i,
        .input:not(:placeholder-shown) + i {
            color: #000000;
        }
        
        .input-wrapper i {
            color: #666666;
            font-size: 16px;
        }
        
        .password-wrapper {
            position: relative;
        }
        
        .password-toggle {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #666666;
            cursor: pointer;
            font-size: 16px;
            transition: all 0.3s ease;
            z-index: 10;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
        }
        
        .password-toggle:hover {
            color: #000000;
        }
        
        .password-wrapper .input {
            padding-left: 48px;
        }
        
        
        .login-btn {
            width: 100%;
            padding: 18px;
            font-size: 16px;
            font-weight: 600;
            background: #000000;
            border: none;
            border-radius: 14px;
            color: #ffffff;
            cursor: pointer;
            transition: background 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-top: 12px;
        }
        
        .login-btn:hover {
            background: #1a1a1a;
        }
        
        .btn-text {
            font-weight: 600;
        }
        
        .btn-icon {
            transition: transform 0.3s ease;
        }
        
        .login-btn:hover .btn-icon {
            transform: translateX(-5px);
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }
    </style>
</head>
<body>
    <div class="login-container" id="loginContainer">
        <div class="login-card">
            <div class="login-logo">
                <div class="logo-badge">POS</div>
                <h1>Solo System</h1>
                <p>إدارة المبيعات والمخزون والمعاملات الأخرى</p>
            </div>
            
            <form class="login-form" id="loginForm">
                <h2 style="color: #000000; font-size: 28px; font-weight: 700; margin-bottom: 32px; letter-spacing: -0.5px;">تسجيل الدخول</h2>
                
                <!-- PIN Display -->
                <div class="form-group" style="margin-bottom: 24px;">
                    <label style="display: block; color: #000000; margin-bottom: 12px; font-weight: 600; font-size: 14px;">أدخل رقم PIN</label>
                    <div style="display: flex; justify-content: center; gap: 12px; margin-bottom: 24px;">
                        <div id="pinDisplay" style="display: flex; gap: 8px; justify-content: center;">
                            <div class="pin-dot" style="width: 16px; height: 16px; border-radius: 50%; border: 2px solid #e8e8e8; background: #fafafa;"></div>
                            <div class="pin-dot" style="width: 16px; height: 16px; border-radius: 50%; border: 2px solid #e8e8e8; background: #fafafa;"></div>
                            <div class="pin-dot" style="width: 16px; height: 16px; border-radius: 50%; border: 2px solid #e8e8e8; background: #fafafa;"></div>
                            <div class="pin-dot" style="width: 16px; height: 16px; border-radius: 50%; border: 2px solid #e8e8e8; background: #fafafa;"></div>
                        </div>
                    </div>
                    <div id="pinError" style="text-align: center; color: #e74c3c; font-size: 13px; min-height: 20px; margin-top: 8px; display: none;"></div>
                </div>
                
                <!-- PIN Pad -->
                <div class="pin-pad" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 16px; direction: ltr;">
                    <button type="button" class="pin-key" data-number="1" style="padding: 20px; background: #ffffff; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 24px; font-weight: 700; color: #000000; cursor: pointer; transition: all 0.2s ease;">1</button>
                    <button type="button" class="pin-key" data-number="2" style="padding: 20px; background: #ffffff; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 24px; font-weight: 700; color: #000000; cursor: pointer; transition: all 0.2s ease;">2</button>
                    <button type="button" class="pin-key" data-number="3" style="padding: 20px; background: #ffffff; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 24px; font-weight: 700; color: #000000; cursor: pointer; transition: all 0.2s ease;">3</button>
                    <button type="button" class="pin-key" data-number="4" style="padding: 20px; background: #ffffff; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 24px; font-weight: 700; color: #000000; cursor: pointer; transition: all 0.2s ease;">4</button>
                    <button type="button" class="pin-key" data-number="5" style="padding: 20px; background: #ffffff; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 24px; font-weight: 700; color: #000000; cursor: pointer; transition: all 0.2s ease;">5</button>
                    <button type="button" class="pin-key" data-number="6" style="padding: 20px; background: #ffffff; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 24px; font-weight: 700; color: #000000; cursor: pointer; transition: all 0.2s ease;">6</button>
                    <button type="button" class="pin-key" data-number="7" style="padding: 20px; background: #ffffff; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 24px; font-weight: 700; color: #000000; cursor: pointer; transition: all 0.2s ease;">7</button>
                    <button type="button" class="pin-key" data-number="8" style="padding: 20px; background: #ffffff; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 24px; font-weight: 700; color: #000000; cursor: pointer; transition: all 0.2s ease;">8</button>
                    <button type="button" class="pin-key" data-number="9" style="padding: 20px; background: #ffffff; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 24px; font-weight: 700; color: #000000; cursor: pointer; transition: all 0.2s ease;">9</button>
                    <button type="button" class="pin-key" id="clearBtn" style="padding: 20px; background: #fafafa; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 18px; font-weight: 600; color: #666666; cursor: pointer; transition: all 0.2s ease; grid-column: 1;">مسح</button>
                    <button type="button" class="pin-key" data-number="0" style="padding: 20px; background: #ffffff; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 24px; font-weight: 700; color: #000000; cursor: pointer; transition: all 0.2s ease;">0</button>
                    <button type="button" class="pin-key" id="deleteBtn" style="padding: 20px; background: #fafafa; border: 2px solid #e8e8e8; border-radius: 14px; font-size: 18px; font-weight: 600; color: #666666; cursor: pointer; transition: all 0.2s ease;">
                        <i class="fas fa-backspace"></i>
                        </button>
                </div>
                
                <!-- Enter Button -->
                <button type="button" class="login-btn" id="enterBtn" style="width: 100%; padding: 18px; font-size: 16px; font-weight: 600; background: #000000; border: none; border-radius: 14px; color: #ffffff; cursor: pointer; transition: background 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 8px; opacity: 0.5; pointer-events: none;">
                    <span class="btn-text">دخول</span>
                    <i class="fas fa-arrow-left btn-icon"></i>
                </button>
                
                <style>
                    .pin-key:hover {
                        background: #000000 !important;
                        color: #ffffff !important;
                        border-color: #000000 !important;
                        transform: scale(1.05);
                    }
                    .pin-key:active {
                        transform: scale(0.95);
                    }
                    .pin-dot.filled {
                        background: #000000 !important;
                        border-color: #000000 !important;
                    }
                    #enterBtn.active {
                        opacity: 1 !important;
                        pointer-events: auto !important;
                    }
                    #enterBtn:not(.active) {
                        opacity: 0.5 !important;
                        pointer-events: none !important;
                    }
                    #enterBtn:hover.active {
                        background: #1a1a1a !important;
                    }
                </style>
            </form>
        </div>
    </div>




    <script src="js/firebase-config.js"></script> 
     <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-app-compat.js"></script> 
     <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-firestore-compat.js"></script> 
     <script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-auth-compat.js"></script> 
     <script src="js/firebase.js"></script> 
     <script src="js/firestore_service.js"></script>

<script>
    // 4. منطق لوحة الأرقام (الـ PIN Pad)
    let enteredPIN = '';
    const MAX_PIN_LENGTH = 4;

    function updatePINDisplay() {
        const dots = document.querySelectorAll('.pin-dot');
        dots.forEach((dot, i) => {
            dot.classList.toggle('filled', i < enteredPIN.length);
        });
        document.getElementById('enterBtn').classList.toggle('active', enteredPIN.length === MAX_PIN_LENGTH);
    }

    function enterPIN(num) {
        if (enteredPIN.length < MAX_PIN_LENGTH) {
            enteredPIN += num;
            updatePINDisplay();
            if (enteredPIN.length === MAX_PIN_LENGTH) verifyPIN();
        }
    }

    function deleteLast() {
        enteredPIN = enteredPIN.slice(0, -1);
        updatePINDisplay();
    }

    function clearPIN() {
        enteredPIN = '';
        updatePINDisplay();
    }

    // ربط الزراير بالوظائف (عشان الزراير تنطق)
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.pin-key[data-number]').forEach(btn => {
            btn.onclick = () => enterPIN(btn.dataset.number);
        });
        document.getElementById('deleteBtn').onclick = deleteLast;
        document.getElementById('clearBtn').onclick = clearPIN;
        document.getElementById('enterBtn').onclick = verifyPIN;
    });

    async function verifyPIN() {
        if (enteredPIN.length !== 4) return;
        const btn = document.getElementById('enterBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

        const user = await window.FirestoreService.verifyPin(enteredPIN);
        if (user) {
            localStorage.setItem('isLoggedIn', 'true');
            localStorage.setItem('userRole', user.role);
            localStorage.setItem('username', user.name);
            window.location.href = 'index.html';
        } else {
            alert('❌ رقم PIN غير صحيح');
            clearPIN();
            btn.disabled = false;
            btn.innerHTML = '<span>دخول</span> <i class="fas fa-arrow-left"></i>';
        }
    }
</script>
</body>
</html>
