<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مسح الطلبات</title>
    <style>
        * {
            font-family: 'Cairo', Arial, sans-serif;
        }
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: #f5f5f5;
            margin: 0;
            padding: 20px;
        }
        .container {
            background: white;
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            text-align: center;
            max-width: 500px;
            width: 100%;
        }
        h1 {
            color: #e74c3c;
            margin-bottom: 20px;
        }
        .info {
            background: #fff3cd;
            border: 1px solid #ffc107;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            color: #856404;
        }
        button {
            background: #e74c3c;
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin: 10px;
            transition: all 0.3s;
        }
        button:hover {
            background: #c0392b;
            transform: translateY(-2px);
        }
        .result {
            margin-top: 20px;
            padding: 15px;
            border-radius: 8px;
            display: none;
        }
        .result.success {
            background: #d4edda;
            border: 1px solid #28a745;
            color: #155724;
            display: block;
        }
        .result.error {
            background: #f8d7da;
            border: 1px solid #dc3545;
            color: #721c24;
            display: block;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🗑️ مسح جميع الطلبات</h1>
        <div class="info">
            ⚠️ تحذير: سيتم مسح جميع الطلبات من localStorage بما في ذلك:
            <ul style="text-align: right; margin: 10px 0;">
                <li>الطلبات العادية (orders)</li>
                <li>الطلبات المعلقة (ordersOnHold)</li>
                <li>تاريخ المبيعات (salesHistory)</li>
                <li>الطلبات المستأنفة (resumeOrder)</li>
            </ul>
            هذا الإجراء لا يمكن التراجع عنه!
        </div>
        <button onclick="clearOrders()">مسح جميع الطلبات</button>
        <div id="result" class="result"></div>
    </div>

    <script>
        function clearOrders() {
            if (!confirm('هل أنت متأكد من مسح جميع الطلبات؟ هذا الإجراء لا يمكن التراجع عنه!')) {
                return;
            }

            try {
                // قائمة بجميع مفاتيح الطلبات
                const orderKeys = [
                    'orders',
                    'ordersOnHold',
                    'salesHistory',
                    'resumeOrder'
                ];

                // مسح المفاتيح
                orderKeys.forEach(key => {
                    localStorage.removeItem(key);
                    // إعادة تهيئة كمصفوفات فارغة
                    if (key === 'orders' || key === 'ordersOnHold' || key === 'salesHistory') {
                        localStorage.setItem(key, JSON.stringify([]));
                    }
                });

                // عرض رسالة النجاح
                const result = document.getElementById('result');
                result.className = 'result success';
                result.innerHTML = '✅ تم مسح جميع الطلبات بنجاح!<br>يمكنك الآن إغلاق هذه الصفحة.';
                
                console.log('✅ تم مسح جميع الطلبات من localStorage');
            } catch (error) {
                const result = document.getElementById('result');
                result.className = 'result error';
                result.innerHTML = '❌ حدث خطأ: ' + error.message;
                console.error('❌ خطأ في مسح الطلبات:', error);
            }
        }

        // عرض عدد الطلبات الحالية
        window.addEventListener('load', () => {
            const orders = JSON.parse(localStorage.getItem('orders') || '[]');
            const ordersOnHold = JSON.parse(localStorage.getItem('ordersOnHold') || '[]');
            const salesHistory = JSON.parse(localStorage.getItem('salesHistory') || '[]');
            
            const total = orders.length + ordersOnHold.length + salesHistory.length;
            
            if (total > 0) {
                const info = document.querySelector('.info');
                info.innerHTML += `<br><strong>عدد الطلبات الحالية: ${total}</strong>`;
            }
        });
    </script>
</body>
</html>
