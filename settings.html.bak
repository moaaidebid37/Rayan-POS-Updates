    <!-- Core Libraries -->
  

    <!-- Firebase Compat SDKs (Order is important) -->
  
  
  

    <!-- Application Services (Order is important) -->
  
  
  
  
  
  
    
    <!-- Other Scripts -->
  
  
  
  
  
  
    <script>
        // Helper function to wait for FirestoreService to be ready
        window.waitForFirestoreService = function(timeoutMs = 5000) {
            return new Promise((resolve) => {
                if (window.FirestoreService && typeof window.FirestoreService.getCollection === 'function') {
                    resolve(true);
                    return;
                }

                const startTime = Date.now();
                const interval = setInterval(() => {
                    if (window.FirestoreService && typeof window.FirestoreService.getCollection === 'function') {
                        clearInterval(interval);
                        resolve(true);
                    } else if (Date.now() - startTime > timeoutMs) {
                        clearInterval(interval);
                        resolve(false);
                    }
                }, 100); // Check every 100ms
            });
        }

        // Check login
        // Check login and apply permissions
        if (typeof Auth !== 'undefined') {
            Auth.checkLogin();
            Auth.checkPageAccess('settings.html');
            Auth.applyPermissions();
        } else {
            if (localStorage.getItem('isLoggedIn') !== 'true') {
                window.location.href = 'login.html';
            }
        }
        
        function logout() {
            if (typeof Auth !== 'undefined') {
                Auth.logout();
            } else {
                localStorage.removeItem('isLoggedIn');
                localStorage.removeItem('username');
                localStorage.removeItem('userType');
                window.location.href = 'login.html';
            }
        }

        // New robust way to handle header button clicks
        document.addEventListener('DOMContentLoaded', () => {
            const clearDataBtn = document.getElementById('clearDataBtn');
            if (clearDataBtn) {
                clearDataBtn.addEventListener('click', clearOperationalDataOnly);
            }

            const refreshButton = document.querySelector('.header-action-btn[title=\"تحديث الصفحة\"]');
            const notificationButton = document.querySelector('.header-action-btn[title=\"تنبيهات المطبخ\"]');

            function handleRefreshClick() {
                window.location.reload();
            }

            function showStockNotificationsClick() {
                alert('سيتم عرض إشعارات المخزون هنا.');
            }

            if (refreshButton) {
                refreshButton.removeAttribute('onclick'); 
                refreshButton.addEventListener('click', handleRefreshClick);
            }

            if (notificationButton) {
                notificationButton.removeAttribute('onclick');
                notificationButton.addEventListener('click', showStockNotificationsClick);
            }
        });
        
        // Global function for switching sections (works in Electron)
        window.switchSettingsSection = function(section, element) {
            console.log('switchSettingsSection called:', section);
            
            // Remove active from all
            document.querySelectorAll('.settings-nav-item').forEach(nav => nav.classList.remove('active'));
            document.querySelectorAll('.settings-section').forEach(sec => sec.classList.remove('active'));
            
            // Add active to clicked item
            if (element) {
                element.classList.add('active');
            }
            
            const sectionEl = document.getElementById(section + 'Section');
            if (sectionEl) {
                sectionEl.classList.add('active');
                console.log('Section activated:', section + 'Section');
            } else {
                console.error('Section not found:', section + 'Section');
            }
            
            // Load store name in general section
            if (section === 'general') {
                setTimeout(() => {
                    const storeNameInput = document.getElementById('storeNameInput');
                    if (storeNameInput) {
                        storeNameInput.value = DataManager.getStoreName();
                        console.log('Store name loaded:', storeNameInput.value);
                    }
                }, 100);
            }
            
            // تحميل إعدادات الضرائب عند فتح قسم الضرائب
            if (section === 'tax') {
                loadTaxSettings();
            }
            
            // Load invoice settings when invoice section is activated
            if (section === 'invoice') {
                loadInvoiceSettings();
            }

            if (section === 'aggregators') {
                loadAggregators();
            }
            
            // تحميل المستخدمين عند فتح قسم إدارة المستخدمين - بدون شرط Role
            if (section === 'users') {
                // انتظار FirestoreService إذا لم يكن جاهزاً
                const waitAndLoad = async () => {
                    if (window.FirestoreService && window.FirestoreService.getAllUsers) {
                        loadUsers(0);
                    } else {
                        // انتظار firestoreReady event
                        const onReady = () => {
                            window.removeEventListener('firestoreReady', onReady);
                            setTimeout(() => loadUsers(0), 200);
                        };
                        window.addEventListener('firestoreReady', onReady, { once: true });
                        
                        // Fallback: محاولة بعد 1 ثانية
                        setTimeout(() => {
                            if (window.FirestoreService && window.FirestoreService.getAllUsers) {
                                loadUsers(0);
                            } else {
                                // استخدام localStorage كبديل
                                loadUsers(0);
                            }
                        }, 1000);
                    }
                };
                waitAndLoad();
            }
        };
        
        // Initialize on DOM ready (works in both browser and Electron)
        async function initializeSettings() {
            console.log('Initializing settings page...');
            initSettingsNav();
            loadSettings();
            
            // Load store name in general section
            const storeNameInput = document.getElementById('storeNameInput');
            if (storeNameInput) {
                storeNameInput.value = await DataManager.getStoreName();
            }
            
            // Update store info
            if (typeof updateStoreInfo === 'function') {
                updateStoreInfo();
            }
            
            // تحميل المستخدمين إذا كان قسم المستخدمين نشطاً
            const usersSection = document.getElementById('usersSection');
            const isUsersSectionActive = usersSection && usersSection.classList.contains('active');
            
            if (isUsersSectionActive) {
                // Wait for FirestoreService to be ready
                const waitForFirestore = () => {
                    if (window.FirestoreService && window.FirestoreService.getAllUsers) {
                        loadUsers();
                    } else {
                        // Wait for firestoreReady event
                        window.addEventListener('firestoreReady', () => {
                            loadUsers();
                        }, { once: true });
                        // Also try after a delay
                        setTimeout(() => {
                            if (window.FirestoreService && window.FirestoreService.getAllUsers) {
                loadUsers();
            }
                        }, 1000);
                    }
                };
                waitForFirestore();
            }
        }
        
        // Try multiple initialization methods for Electron compatibility
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initializeSettings);
        } else {
            // DOM already loaded
            initializeSettings();
        }
        
        // Fallback for Electron (sometimes DOMContentLoaded fires too early)
        setTimeout(() => {
            const navItems = document.querySelectorAll('.settings-nav-item');
            if (navItems.length > 0) {
                console.log('Re-initializing nav (fallback for Electron)');
                initSettingsNav();
            }
        }, 500);
        
        function loadSettings() {
            // لم يعد هناك إعدادات أخرى أو حساب شخصي
        }
        
        function initSettingsNav() {
            const navItems = document.querySelectorAll('.settings-nav-item');
            console.log('initSettingsNav: Found', navItems.length, 'nav items');
            
            navItems.forEach(item => {
                // Remove any existing listeners by cloning
                const newItem = item.cloneNode(true);
                item.parentNode.replaceChild(newItem, item);
                
                newItem.addEventListener('click', async function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    console.log('Nav item clicked:', this.dataset.section);
                    
                    // Remove active from all
                    document.querySelectorAll('.settings-nav-item').forEach(nav => nav.classList.remove('active'));
                    document.querySelectorAll('.settings-section').forEach(section => section.classList.remove('active'));
                    
                    // Add active to clicked item
                    this.classList.add('active');
                    
                    const section = this.dataset.section;
                    console.log('Switching to section:', section);
                    
                    const sectionEl = document.getElementById(section + 'Section');
                    if (sectionEl) {
                        sectionEl.classList.add('active');
                        console.log('Section activated:', section + 'Section');
                    } else {
                        console.error('Section not found:', section + 'Section');
                    }
                    
                    // Load store name in general section
                    if (section === 'general') {
                        const storeNameInput = document.getElementById('storeNameInput');
                        if (storeNameInput) {
                            storeNameInput.value = await DataManager.getStoreName();
                            console.log('Store name loaded:', storeNameInput.value);
                        }
                    }
                    
                    // تحميل إعدادات الضرائب عند فتح قسم الضرائب
                    if (section === 'tax') {
                        loadTaxSettings();
                    }
                    
                    if (section === 'invoice') {
                        loadInvoiceSettings();
                    }

                    if (section === 'aggregators') {
                        loadAggregators();
                    }
                    
                    // تحميل المستخدمين عند فتح قسم إدارة المستخدمين - بدون شرط Role
                    if (section === 'users') {
                        // انتظار FirestoreService إذا لم يكن جاهزاً
                        const waitAndLoad = async () => {
                            if (window.FirestoreService && window.FirestoreService.getAllUsers) {
                                loadUsers(0);
                            } else {
                                // انتظار firestoreReady event
                                const onReady = () => {
                                    window.removeEventListener('firestoreReady', onReady);
                                    setTimeout(() => loadUsers(0), 200);
                                };
                                window.addEventListener('firestoreReady', onReady, { once: true });
                                
                                // Fallback: محاولة بعد 1 ثانية
                                setTimeout(() => {
                                    if (window.FirestoreService && window.FirestoreService.getAllUsers) {
                                        loadUsers(0);
                                    } else {
                                        // استخدام localStorage كبديل
                                        loadUsers(0);
                                    }
                                }, 1000);
                            }
                        };
                        waitAndLoad();
                    }
                });
            });
        }
        
        // إدارة المستخدمين
        let editingUserId = null;
        
        let isLoadingUsers = false; // Flag to prevent concurrent loads
        
        async function loadUsers(retryCount = 0) { 
            const usersList = document.getElementById('usersList'); 
            if (!usersList) { 
                console.warn('⚠️ usersList element not found'); 
                return; 
            } 
            
            if (isLoadingUsers) return; 
            isLoadingUsers = true; 
            
            usersList.innerHTML = ` 
                <div style=\"text-align: center; padding: var(--spacing-xl);\"> 
                    <div class=\"spinner\" style=\"width: 48px; height: 48px; border: 4px solid #f0f0f0; border-top-color: #000000; border-radius: 50%; margin: 0 auto var(--spacing-md); animation: spin 1s linear infinite;\"></div> 
                    <div style=\"font-size: 14px; color: #666666; font-weight: 500;\">جاري التحميل...</div> 
                </div> 
            `; 
            
            try { 
                let users = []; 
                
                // التعديل السحري: لو أونلاين، جيب من الفايربيز واحفظ نسخة باك أب في الجهاز 
                if (navigator.onLine && window.FirestoreService && window.FirestoreService.getAllUsers) { 
                    try { 
                        const fetchedUsers = await window.FirestoreService.getAllUsers(); 
                        users = fetchedUsers.filter(u => u.deleted !== true && u.active !== false); 
                        
                        // السر هنا: حفظ نسخة في اللوكال ستورج عشان تلاقيها لما النت يقطع! 
                        localStorage.setItem('users', JSON.stringify(users)); 
                    } catch (firestoreError) { 
                        const localUsers = JSON.parse(localStorage.getItem('users') || '[]'); 
                        users = localUsers.filter(u => !u.deleted && u.active !== false); 
                    } 
                } else { 
                    // التعديل التاني: لو أوفلاين، اقرأ من اللوكال فوراً بدون تأخير 
                    const localUsers = JSON.parse(localStorage.getItem('users') || '[]'); 
                    users = localUsers.filter(u => !u.deleted && u.active !== false); 
                } 
                
                if (users.length === 0) { 
                    usersList.innerHTML = ` 
                        <div style=\"text-align: center; padding: var(--spacing-xl); background: linear-gradient(135deg, #fafafa 0%, #ffffff 100%); border-radius: 16px; border: 2px dashed #e8e8e8;\"> 
                            <i class=\"fas fa-users\" style=\"font-size: 64px; color: #cccccc; margin-bottom: var(--spacing-md);\"></i> 
                            <div style=\"font-size: 18px; font-weight: 600; color: #000000; margin-bottom: 8px;\">لا يوجد مستخدمين</div> 
                            <div style=\"font-size: 14px; color: #666666; margin-bottom: var(--spacing-lg);\">ابدأ بإضافة مستخدم جديد لإدارة النظام</div> 
                            <button class=\"btn btn-primary\" onclick=\"openAddUserModal()\" style=\"display: inline-flex; align-items: center; gap: 8px;\"> 
                                <i class=\"fas fa-plus\"></i> 
                                <span>إضافة مستخدم جديد</span> 
                            </button> 
                        </div> 
                    `; 
                    isLoadingUsers = false; 
                    return; 
                } 
                
                usersList.innerHTML = ''; 
                
                for (const user of users) { 
                    const userCard = document.createElement('div'); 
                    userCard.className = 'user-card'; 
                    
                    const username = user.displayName || user.name || user.username || 'مستخدم'; 
                    const firstLetter = username.charAt(0).toUpperCase(); 
                    const userRole = user.role || 'cashier'; 
                    let roleLabel, roleDisplayClass, roleIcon; 
                    
                    let stats = { sessions: 0, orders: 0, totalRevenue: 0 }; 
                    const cashierName = username; 
                    if (typeof getCashierStats === 'function') { 
                        stats = await getCashierStats(cashierName); 
                    } 
                    
                    if (userRole === 'owner' || userRole === 'admin') { 
                        roleLabel = 'المالك'; 
                        roleDisplayClass = 'owner'; 
                        roleIcon = '👑'; 
                    } else if (userRole === 'cashier') { 
                        roleLabel = 'كاشير'; 
                        roleDisplayClass = 'cashier'; 
                        roleIcon = '💼'; 
                    } else { 
                        roleLabel = userRole; 
                        roleDisplayClass = 'custom'; 
                        roleIcon = '👤'; 
                    } 
                    
                    userCard.innerHTML = ` 
                        <div class=\"user-card-header\"> 
                            <div class=\"user-avatar\">${firstLetter}</div> 
                            <div class=\"user-info\"> 
                                <div class=\"user-name\">${username}</div> 
                                <div class=\"user-email\">${user.email || ''}</div> 
                            </div> 
                            <span class=\"user-role ${roleDisplayClass}\">${roleIcon} ${roleLabel}</span> 
                        </div> 
                        <div class=\"cashier-stats\"> 
                            <div class=\"stat-item\"> 
                                <div class=\"stat-value\">${stats.sessions}</div> 
                                <div class=\"stat-label\">جلسات</div> 
                            </div> 
                            <div class=\"stat-item\"> 
                                <div class=\"stat-value\">${stats.orders}</div> 
                                <div class=\"stat-label\">طلبات</div> 
                            </div> 
                            <div class=\"stat-item\"> 
                                <div class=\"stat-value\">${typeof Utils !== 'undefined' ? Utils.formatCurrency(stats.totalRevenue) : stats.totalRevenue}</div> 
                                <div class=\"stat-label\">مبيعات</div> 
                            </div> 
                        </div> 
                        <div class=\"user-actions\"> 
                            <button class=\"btn-icon\" data-tooltip=\"تعديل\" onclick=\"editUser('${user.id || user.uid || user.email}')\"> 
                                <i class=\"fas fa-edit\"></i> 
                            </button> 
                            <button class=\"btn-icon\" data-tooltip=\"حذف\" onclick=\"deleteUser('${user.id || user.uid || user.email}', '${username}')\" style=\"color: #e74c3c;\"> 
                                <i class=\"fas fa-trash\"></i> 
                            </button> 
                        </div> 
                    `; 
                    
                    usersList.appendChild(userCard); 
                } 
            } catch (error) { 
                console.error('❌ Error loading users:', error); 
                usersList.innerHTML = ` 
                    <div style=\"text-align: center; padding: var(--spacing-xl); color: #e74c3c;\"> 
                        <i class=\"fas fa-exclamation-triangle\" style=\"font-size: 48px; margin-bottom: var(--spacing-md);\"></i> 
                        <div>حدث خطأ أثناء تحميل المستخدمين</div> 
                        <button class=\"btn btn-primary\" onclick=\"loadUsers(0)\" style=\"margin-top: 10px;\">إعادة المحاولة</button> 
                    </div> 
                `; 
            } finally { 
                isLoadingUsers = false; 
            } 
        }
        
        async function getCashierStats(username) {
            try {
                const sessions = await DataManager.getCashSessions();
                const cashierSessions = sessions.filter(s => {
                    const openedBy = s.openedBy || s.cashier || s.userName;
                    const closedBy = s.closedBy || s.cashier || s.userName;
                    return openedBy === username || closedBy === username;
                });
                
                const orders = await DataManager.getOrders();
                const cashierOrders = orders.filter(o => {
                    const orderCashier = o.cashier || o.createdBy || o.userName || o.openedBy;
                    return orderCashier === username;
                });
                const totalRevenue = cashierOrders.reduce((sum, o) => sum + (parseFloat(o.total) || 0), 0);
                
                return {
                    sessions: cashierSessions.length,
                    orders: cashierOrders.length,
                    totalRevenue: totalRevenue
                };
            } catch (error) {
                console.error('Error getting cashier stats:', error);
                return { sessions: 0, orders: 0, totalRevenue: 0 };
            }
        }
        
        function openAddUserModal() {
            editingUserId = null;
            document.getElementById('userModalTitle').textContent = 'إضافة مستخدم جديد';
            document.getElementById('userForm').reset();
            document.getElementById('userModal').classList.add('active');
        }
        
        function closeUserModal() {
            document.getElementById('userModal').classList.remove('active');
            document.getElementById('userForm').reset();
            editingUserId = null;
        }
        
        async function editUser(userId) {
            try {
                let user = null;
                
                // استخدام Firestore إذا كان متاحاً
                if (window.FirestoreService && window.FirestoreService.getAllUsers) {
                    const users = await window.FirestoreService.getAllUsers();
                    user = users.find(u => u.id === userId || u.uid === userId || (u.uid || u.username || u.displayName) === userId);
                } else {
                    // Fallback إلى localStorage
                    const users = JSON.parse(localStorage.getItem('users') || '[]');
                    user = users.find(u => (u.uid || u.username || u.displayName || u.id) === userId);
                }
                
                if (!user) {
                    Notification.error('المستخدم غير موجود');
                    return;
                }
                
                editingUserId = userId;
                document.getElementById('userModalTitle').textContent = 'تعديل المستخدم';
                // تحديث: إعطاء الأولوية لـ displayName ثم name ثم username
                document.getElementById('userDisplayName').value = user.displayName || user.name || user.username || '';
                // عرض PIN الحالي في حقل الإدخال
                document.getElementById('userPin').value = user.pin || '';
                document.getElementById('userPin').required = false;
                document.getElementById('userPin').placeholder = 'أدخل PIN جديد إذا أردت التغيير';
                document.getElementById('userRole').value = user.role === 'admin' ? 'admin' : (user.role === 'manager' ? 'manager' : 'cashier');
                document.getElementById('userModal').classList.add('active');
            } catch (error) {
                console.error('Error editing user:', error);
                Notification.error('حدث خطأ أثناء تحميل بيانات المستخدم');
            }
        }
        
        async function deleteUser(userId, userName) {
            // الحذف مسموح لصاحب المحل/المدير فقط
            try {
                if (typeof Auth !== 'undefined' && typeof Auth.canDelete === 'function' && !Auth.canDelete()) {
                    Notification.error('الحذف مسموح لصاحب المحل فقط');
                    return;
                }
            } catch (_) { /* ignore */ }

            if (!confirm(`هل أنت متأكد من حذف المستخدم \"${userName}\"؟`)) {
                return;
            }
            
            try {
                // حذف محلياً دائماً
                let users = JSON.parse(localStorage.getItem('users') || '[]');
                users = users.filter(u => (u.uid || u.username || u.displayName || u.id) !== userId);
                localStorage.setItem('users', JSON.stringify(users));

                // مزامنة الحذف مع Firebase (Online/Offline) عبر SyncManager
                if (window.SyncManager && typeof window.SyncManager.addToSyncQueue === 'function') {
                    window.SyncManager.addToSyncQueue('users', 'delete', { id: String(userId) });
                } else if (window.FirestoreService && window.FirestoreService.deleteUser && navigator.onLine) {
                    // fallback لو SyncManager غير متاح
                    await window.FirestoreService.deleteUser(userId);
                }

                Notification.success('تم حذف المستخدم بنجاح');
                await loadUsers();
            } catch (error) {
                console.error('Error deleting user:', error);
                Notification.error('حدث خطأ أثناء حذف المستخدم: ' + (error.message || ''));
            }
        }
        
        async function viewCashierHistory(userId, userName) {
            const modal = document.getElementById('cashierHistoryModal');
            const content = document.getElementById('cashierHistoryContent');
            const title = document.getElementById('cashierHistoryTitle');
            
            title.textContent = `تاريخ الكاشير: ${userName}`;
            content.innerHTML = '<div style=\"text-align: center; padding: var(--spacing-lg);\">جاري التحميل...</div>';
            modal.classList.add('active');
            
            try {
                const sessions = await DataManager.getCashSessions();
                const cashierSessions = sessions.filter(s => s.openedBy === userName || s.closedBy === userName);
                
                const orders = await DataManager.getOrders();
                const cashierOrders = orders.filter(o => o.cashier === userName || o.createdBy === userName);
                
                let historyHTML = `
                    <div style=\"margin-bottom: var(--spacing-lg);\">
                        <h4 style=\"color: #000000; font-weight: 700; margin-bottom: var(--spacing-md);\">جلسات الصندوق (${cashierSessions.length})</h4>
                        <div style=\"display: grid; gap: var(--spacing-sm);\">
                `;
                
                if (cashierSessions.length === 0) {
                    historyHTML += '<div style=\"text-align: center; padding: var(--spacing-md); color: #666666;\">لا توجد جلسات</div>';
                } else {
                    cashierSessions.forEach(session => {
                        const openDate = new Date(session.createdAt || session.date).toLocaleDateString('ar-EG', {  });
                        const closeDate = session.closedAt ? new Date(session.closedAt).toLocaleDateString('ar-EG', {  }) : 'لم يتم الإغلاق';
                        historyHTML += `
                            <div style=\"background: #fafafa; padding: var(--spacing-md); border-radius: 8px; border: 1px solid #e8e8e8;\">
                                <div style=\"display: flex; justify-content: space-between; margin-bottom: 8px;\">
                                    <strong>${openDate}</strong>
                                    <span style=\"color: ${session.status === 'closed' ? '#27ae60' : '#f39c12'}; font-weight: 600;\">
                                        ${session.status === 'closed' ? 'مغلقة' : 'مفتوحة'}
                                    </span>
                                </div>
                                <div style=\"font-size: 12px; color: #666666;\">
                                    <div>فتح: ${session.openedBy || 'غير معروف'}</div>
                                    ${session.closedBy ? `<div>إغلاق: ${session.closedBy}</div>` : ''}
                                    <div>المبلغ الافتتاحي: ${Utils.formatCurrency(session.openingAmount || 0)}</div>
                                    ${session.closingAmount ? `<div>المبلغ الإغلاقي: ${Utils.formatCurrency(session.closingAmount)}</div>` : ''}
                                </div>
                            </div>
                        `;
                    });
                }
                
                historyHTML += `
                        </div>
                    </div>
                    <div>
                        <h4 style=\"color: #000000; font-weight: 700; margin-bottom: var(--spacing-md);\">الطلبات (${cashierOrders.length})</h4>
                        <div style=\"display: grid; gap: var(--spacing-sm);\">
                `;
                
                if (cashierOrders.length === 0) {
                    historyHTML += '<div style=\"text-align: center; padding: var(--spacing-md); color: #666666;\">لا توجد طلبات</div>';
                } else {
                    cashierOrders.slice(0, 10).forEach(order => {
                        const orderDate = new Date(order.date).toLocaleDateString('ar-EG', {  });
                        historyHTML += `
                            <div style=\"background: #fafafa; padding: var(--spacing-md); border-radius: 8px; border: 1px solid #e8e8e8;\">
                                <div style=\"display: flex; justify-content: space-between; margin-bottom: 8px;\">
                                    <strong>${order.id}</strong>
                                    <span>${Utils.formatCurrency(order.total || 0)}</span>
                                </div>
                                <div style=\"font-size: 12px; color: #666666;\">
                                    ${orderDate} - ${order.items ? order.items.length : 0} منتج
                                </div>
                            </div>
                        `;
                    });
                    if (cashierOrders.length > 10) {
                        historyHTML += `<div style=\"text-align: center; padding: var(--spacing-md); color: #666666;\">و ${cashierOrders.length - 10} طلب آخر</div>`;
                    }
                }
                
                historyHTML += '</div></div>';
                content.innerHTML = historyHTML;
            } catch (error) {
                console.error('Error loading cashier history:', error);
                content.innerHTML = '<div style=\"text-align: center; padding: var(--spacing-lg); color: #e74c3c;\">حدث خطأ أثناء تحميل التاريخ</div>';
            }
        }
        
        function closeCashierHistoryModal() {
            document.getElementById('cashierHistoryModal').classList.remove('active');
        }
        
        // حذف جميع الطلبات
        async function clearAllOrders() {
            if (!confirm('هل أنت متأكد من حذف جميع الطلبات؟ هذا الإجراء لا يمكن التراجع عنه!')) {
                return;
            }
            
            try {
                // حذف من localStorage
                localStorage.setItem('orders', JSON.stringify([]));
                localStorage.setItem('ordersOnHold', JSON.stringify([]));
                localStorage.setItem('salesHistory', JSON.stringify([]));
                
                // البيانات محذوفة من localStorage فقط (لا يوجد Firebase)
                
                Notification.success('تم حذف جميع الطلبات بنجاح');
            } catch (error) {
                console.error('Error clearing orders:', error);
                Notification.error('حدث خطأ أثناء حذف الطلبات');
            }
        }
        
        // معالج نموذج إضافة/تعديل مستخدم
        document.getElementById('userForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const username = document.getElementById('userDisplayName').value.trim();
            const pin = document.getElementById('userPin').value.trim();
            const role = document.getElementById('userRole').value;
            
            if (!username) {
                Notification.error('يرجى إدخال اسم المستخدم');
                return;
            }
            
            if (!editingUserId && !pin) {
                Notification.error('رقم PIN مطلوب للمستخدمين الجدد');
                return;
            }
            
            if (pin && (pin.length !== 4 || !/^\d{4}$/.test(pin))) {
                Notification.error('رقم PIN يجب أن يكون 4 أرقام');
                return;
            }
            
            try {
                if (editingUserId) {
                    // تحديث مستخدم موجود
                    if (window.FirestoreService && window.FirestoreService.updateUser) {
                        // تحديث شامل للمستخدم في Firestore
                        const updateData = {
                            name: username,
                            displayName: username, // إضافة displayName أيضاً
                            username: username, // إضافة username أيضاً
                            role: role, // حفظ الدور كما هو بدون تحويل
                            updatedAt: new Date().toISOString()
                        };
                        
                        // تحديث PIN إذا تم إدخاله، وإلا احتفظ بالقيمة الحالية
                        if (pin && pin.trim() !== '') {
                            updateData.pin = String(pin); // تحويل PIN لـ String
                        }
                        
                        console.log('🔄 Updating user in Firestore:', editingUserId, updateData);
                        await window.FirestoreService.updateUser(editingUserId, updateData);
                        
                        // تحديث فوري في LocalStorage بعد نجاح Firestore
                        let localUsers = JSON.parse(localStorage.getItem('users') || '[]');
                        const localIndex = localUsers.findIndex(u => (u.uid || u.username || u.displayName || u.id) === editingUserId);
                        
                        if (localIndex !== -1) {
                            localUsers[localIndex] = {
                                ...localUsers[localIndex],
                                name: username,
                                displayName: username,
                                username: username,
                                role: role, // حفظ الدور كما هو بدون تحويل
                                updatedAt: updateData.updatedAt
                            };
                            
                            // تحديث PIN فقط إذا تم إدخاله
                            if (pin && pin.trim() !== '') {
                                localUsers[localIndex].pin = String(pin);
                            }
                            
                            localStorage.setItem('users', JSON.stringify(localUsers));
                            console.log('✅ LocalStorage updated successfully');
                        }
                        
                        Notification.success('تم تحديث المستخدم بنجاح');
                        closeUserModal();
                        await loadUsers(); // إعادة تحميل الواجهة فوراً
                        
                    } else {
                        // Fallback إلى localStorage
                        let users = JSON.parse(localStorage.getItem('users') || '[]');
                        const index = users.findIndex(u => (u.uid || u.username || u.displayName || u.id) === editingUserId);
                        if (index !== -1) {
                            users[index] = {
                                ...users[index],
                                displayName: username,
                                username: username,
                                name: username,
                                role: role, // حفظ الدور كما هو بدون تحويل
                                updatedAt: new Date().toISOString()
                            };
                            // تحديث PIN فقط إذا تم إدخاله
                            if (pin && pin.trim() !== '') {
                                users[index].pin = String(pin); // تحويل PIN لـ String
                            }
                            localStorage.setItem('users', JSON.stringify(users));
                        }
                        Notification.success('تم تحديث المستخدم بنجاح');
                        closeUserModal();
                        await loadUsers();
                    }
                } else {
                    // إضافة مستخدم جديد
                    if (window.FirestoreService && window.FirestoreService.addUser) {
                        await window.FirestoreService.addUser({
                            name: username,
                            displayName: username, // إضافة displayName أيضاً
                            username: username, // إضافة username أيضاً
                            pin: pin,
                            role: role
                        });
                        Notification.success('تم إضافة المستخدم بنجاح');
                        closeUserModal();
                        await loadUsers();
                    } else {
                        // Fallback إلى localStorage
                        await createUserInLocalStorage(username, pin, role);
                    }
                    
                    // تحديث LocalStorage فوراً بعد إضافة المستخدم الجديد (للتزامن)
                    if (window.FirestoreService && window.FirestoreService.getAllUsers) {
                        try {
                            const freshUsers = await window.FirestoreService.getAllUsers();
                            localStorage.setItem('users', JSON.stringify(freshUsers));
                            console.log('✅ LocalStorage synced with fresh Firestore data');
                        } catch (syncError) {
                            console.warn('⚠️ Failed to sync LocalStorage:', syncError);
                        }
                    }
                }
            } catch (error) {
                console.error('Error saving user:', error);
                Notification.error('حدث خطأ أثناء حفظ المستخدم: ' + (error.message || ''));
            }
        });
        
        // تصدير جميع البيانات إلى ملف CSV شامل
        async function exportAllDataToExcel() {
            try {
                // جلب جميع البيانات
                // ملاحظة: المصاريف يتم أخذها من expensesHistory فقط (تاريخ المصاريف)
                // لا يتم أخذ أي بيانات من expenses (المصاريف الحالية)
                const orders = await DataManager.getOrders() || [];
                const sales = await DataManager.getSalesHistory() || [];
                
                // ===== المصاريف: نأخذ البيانات من expensesHistory فقط =====
                // ⚠️ مهم جداً: لا يتم أخذ أي بيانات من expenses (المصاريف الحالية) على الإطلاق
                // ✅ المصدر الوحيد للبيانات هو expensesHistory (تاريخ المصاريف)
                console.log('=== بدء تصدير Excel ===');
                console.log('جاري جلب expensesHistory...');
                const expensesHistory = await DataManager.getExpensesHistory() || [];
                console.log('✅ تم جلب expensesHistory');
                console.log('✅ عدد المصاريف في expensesHistory:', expensesHistory.length);
                console.log('✅ expensesHistory:', JSON.stringify(expensesHistory, null, 2));
                
                // ⚠️ تأكيد: لا نستخدم expenses على الإطلاق
                // const expenses = await DataManager.getExpenses(); // ❌ محذوف - لا نستخدمه
                
                const sessions = await DataManager.getCashSessions() || [];
                const employees = JSON.parse(localStorage.getItem('employees') || '[]');
                const menuItems = JSON.parse(localStorage.getItem('menuItems') || '[]');
                
                // إنشاء ملف Excel متعدد الأوراق (CSV متعدد)
                let csv = '';
                
                // ورقة الطلبات
                csv += '=== الطلبات ===\\n';
                csv += 'رقم الطلب,التاريخ,النوع,عدد المنتجات,الإجمالي,الكاشير,الحالة\\n';
                orders.forEach(order => {
                    const date = order.date ? new Date(order.date).toLocaleDateString('ar-EG', {  }) : '-';
                    const itemsCount = order.items ? order.items.length : 0;
                    csv += `${order.id || '-'},${date},${order.type || 'takeaway'},${itemsCount},${order.total || 0},${order.cashier || order.createdBy || '-'},${order.status || 'completed'}\\n`;
                });
                csv += '\\n';
                
                // ورقة المبيعات
                csv += '=== المبيعات ===\\n';
                csv += 'رقم المبيعة,رقم الطلب,التاريخ,المبلغ,التاريخ التجاري\\n';
                sales.forEach(sale => {
                    const date = sale.date ? new Date(sale.date).toLocaleDateString('ar-EG', {  }) : '-';
                    csv += `${sale.id || '-'},${sale.orderId || '-'},${date},${sale.amount || 0},${sale.businessDate || '-'}\\n`;
                });
                csv += '\\n';
                
                // ورقة المصاريف
                csv += '=== المصاريف ===\\n';
                csv += 'رقم المصروف,النوع,التاريخ,المبلغ,الوصف,من أنشأه,تاريخ الإنشاء,تاريخ الجلسة\\n';
                
                console.log('=== إضافة المصاريف إلى CSV ===');
                console.log('expenses.length:', expenses.length);
                
                // التأكد من أن expenses موجود وليس فارغاً
                if (expenses && expenses.length > 0) {
                    console.log('✅ يوجد', expenses.length, 'مصروف في expenses');
                    let count = 0;
                    expenses.forEach(expense => {
                        count++;
                        const date = expense.date ? new Date(expense.date).toLocaleDateString('ar-EG', {  }) : '-';
                        const createdAt = expense.createdAt ? new Date(expense.createdAt).toLocaleDateString('ar-EG', {  }) : '-';
                        csv += `${expense.id || '-'},${expense.category || expense.type || '-'},${date},${expense.amount || 0},${expense.description || '-'},${expense.createdBy || '-'},${createdAt},${expense.sessionDate || '-'}\\n`;
                    });
                    console.log('✅ تم إضافة', count, 'مصروف إلى CSV');
                } else {
                    // إذا كان expenses فارغاً، لا نضيف أي بيانات
                    console.log('⚠️ expenses فارغ - لا توجد بيانات');
                    csv += 'لا توجد بيانات في المصاريف\\n';
                }
                csv += '\\n';
                
                // ورقة الشيفتات
                csv += '=== الشيفتات النقدية ===\\n';
                csv += 'رقم الشيفت,التاريخ,من فتحه,وقت الفتح,وقت الإغلاق,المبلغ الابتدائي,المبلغ النهائي,المبلغ المتوقع,الفرق,الحالة\\n';
                sessions.forEach(session => {
                    const date = session.date ? new Date(session.date).toLocaleDateString('ar-EG', {}) : '-';
                    const openedAt = session.createdAt ? new Date(session.createdAt).toLocaleString('ar-EG', { hour: '2-digit', minute: '2-digit' }) : '-';
                    const closedAt = session.closedAt ? new Date(session.closedAt).toLocaleString('ar-EG', { hour: '2-digit', minute: '2-digit' }) : '-';
                    const openingAmount = session.openingAmount || 0;
                    const closingAmount = session.closingAmount || 0;
                    const expectedAmount = openingAmount + (session.totalSales || 0) - (session.totalExpenses || 0);
                    const difference = closingAmount - expectedAmount;
                    csv += `${session.id || '-'},${date},${session.openedBy || '-'},${openedAt},${closedAt},${openingAmount},${closingAmount},${expectedAmount},${difference},${session.status || 'open'}\\n`;
                });
                csv += '\\n';
                
                // ورقة المخزون / المنيو
                csv += '=== المخزون (المنيو) ===\\n';
                csv += 'رقم الصنف,الاسم,الفئة,النوع,سعر البيع,سعر التكلفة,المكسب للوحدة,الكمية الحالية,حد التنبيه الأصفر,حد التنبيه الأحمر\\n';
                menuItems.forEach(item => {
                    const sellingPrice = item.price || 0;
                    const costPrice = item.costPrice || 0;
                    const profit = sellingPrice - costPrice;
                    csv += `${item.id || '-'},${item.name || '-'},${item.categoryName || '-'},${item.type || 'physical'},${sellingPrice},${costPrice},${profit},${item.stock || 0},${item.minStockLimit || 0},${item.criticalStockLimit || 0}\\n`;
                });
                csv += '\\n';
                
                // ورقة الموظفين
                csv += '=== الموظفون ===\\n';
                csv += 'رقم الموظف,الاسم,الدور,الراتب الشهري,رقم الهاتف\\n';
                employees.forEach(emp => {
                    csv += `${emp.id || '-'},${emp.name || '-'},${emp.role || '-'},${emp.salary || 0},${emp.phone || '-'}\\n`;
                });
                
                // تحميل الملف
                const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                const url = URL.createObjectURL(blob);
                const now = new Date();
                const year = now.getFullYear();
                const month = String(now.getMonth() + 1).padStart(2, '0');
                const day = String(now.getDate()).padStart(2, '0');
                const fileName = `rayan-pos-backup-${year}-${month}-${day}.csv`;
                link.setAttribute('href', url);
                link.setAttribute('download', fileName);
                link.style.visibility = 'hidden';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                
                if (typeof Notification !== 'undefined') {
                    Notification.success('تم تصدير جميع البيانات بنجاح');
                } else {
                    alert('تم تصدير جميع البيانات بنجاح');
                }
            } catch (error) {
                console.error('Error exporting data:', error);
                if (typeof Notification !== 'undefined') {
                    Notification.error('حدث خطأ أثناء تصدير البيانات');
                } else {
                    alert('حدث خطأ أثناء تصدير البيانات');
                }
            }
        }
        
        // دالة مساعدة لإنشاء مستخدم في localStorage
        async function createUserInLocalStorage(username, pin, role) {
            let users = JSON.parse(localStorage.getItem('users') || '[]');
            
            // التحقق من عدم وجود مستخدم بنفس الاسم أو PIN
            if (users.some(u => (u.username || u.displayName) === username)) {
                Notification.error('اسم المستخدم موجود بالفعل');
                return;
            }
            
            if (users.some(u => u.pin === pin)) {
                Notification.error('رقم PIN موجود بالفعل');
                return;
            }
            
            const newUser = {
                uid: 'USER-' + Date.now(),
                id: 'USER-' + Date.now(),
                username: username,
                displayName: username,
                name: username,
                role: role === "admin" || role === "owner" || role === "manager" ? "admin" : "cashier",
                pin: String(pin), // تحويل PIN لـ String
                createdAt: new Date().toISOString(),
                createdBy: typeof Auth !== 'undefined' ? Auth.getUsername() : 'owner',
                active: true
            };
            users.push(newUser);
            localStorage.setItem('users', JSON.stringify(users));
            Notification.success('تم إنشاء المستخدم بنجاح');
            closeUserModal();
            await loadUsers(); // إعادة تحميل الواجهة فوراً
        }
        
        function saveGeneralSettings(event) { 
            event.preventDefault(); 
            
            const storeName = document.getElementById('storeNameInput').value.trim(); 
            
            if (!storeName) { 
                if (typeof Notification !== 'undefined') Notification.error('يرجى إدخال اسم المتجر'); 
                return; 
            } 
            
            // 1. الحفظ المحلي فوراً 
            localStorage.setItem('solo_store_name', storeName); 
            if (typeof DataManager !== 'undefined' && typeof DataManager.setStoreName === 'function') { 
                DataManager.setStoreName(storeName); 
            } 
            
            // 2. تحديث كائن الإعدادات الشامل للمزامنة 
            let appSettings = JSON.parse(localStorage.getItem('appSettings') || '{}'); 
            appSettings.storeName = storeName; 
            appSettings.id = 'global_settings'; // ID ثابت للإعدادات 
            localStorage.setItem('appSettings', JSON.stringify(appSettings)); 
            
            // 3. المزامنة مع فايربيز (يشتغل أوفلاين وأونلاين) 
            if (typeof window !== 'undefined' && window.SyncManager) { 
                appSettings._synced = false; 
                window.SyncManager.addToSyncQueue('settings', 'update', appSettings, 'global_settings'); 
            } 
            
            // 4. تحديث الواجهة فوراً 
            if (typeof updateStoreInfo === 'function') { 
                updateStoreInfo(); 
            } 
            
            if (typeof Notification !== 'undefined') { 
                Notification.success('تم حفظ الإعدادات بنجاح!'); 
            } else { 
                alert('تم حفظ الإعدادات بنجاح!'); 
            } 
        }
        
        function resetStoreName() {
            if (!confirm('هل تريد إعادة تعيين اسم المتجر إلى القيمة الافتراضية؟')) {
                return;
            }
            
            localStorage.removeItem('solo_store_name');
            document.getElementById('storeNameInput').value = 'Solo Restaurant';
            
            // Update UI immediately
            if (typeof updateStoreInfo === 'function') {
                updateStoreInfo();
            }
            
            Notification.success('تم إعادة تعيين اسم المتجر');
        }
        
        // إعدادات الضرائب ورسوم الخدمة
        function loadTaxSettings() {
            const taxSettings = JSON.parse(localStorage.getItem('taxServiceSettings') || '{}');
            
            const taxRateInput = document.getElementById('taxRateInput');
            const serviceChargeInput = document.getElementById('serviceChargeInput');
            const taxIdInput = document.getElementById('taxIdInput');
            
            // إذا كانت هناك قيمة محفوظة، عرضها. وإلا اترك الحقل فارغاً
            if (taxRateInput) {
                taxRateInput.value = taxSettings.taxRate !== undefined ? taxSettings.taxRate : '';
            }
            
            if (serviceChargeInput) {
                serviceChargeInput.value = taxSettings.serviceChargeRate !== undefined ? taxSettings.serviceChargeRate : '';
            }
            
            if (taxIdInput) {
                taxIdInput.value = taxSettings.taxId || '';
            }
        }
        
        function saveTaxSettings(event) {
            event.preventDefault();
            
            const taxRateInput = document.getElementById('taxRateInput').value.trim();
            const serviceChargeInput = document.getElementById('serviceChargeInput').value.trim();
            const taxIdInput = document.getElementById('taxIdInput').value.trim();
            
            // إذا كان الحقل فارغاً، لا تطبق ضريبة/رسوم خدمة
            let taxRate = null;
            let serviceChargeRate = null;
            
            if (taxRateInput !== '') {
                taxRate = parseFloat(taxRateInput);
                if (isNaN(taxRate) || taxRate < 0 || taxRate > 100) {
                    Notification.error('يرجى إدخال معدل ضريبة صحيح (0-100)');
                    return;
                }
            }
            
            if (serviceChargeInput !== '') {
                serviceChargeRate = parseFloat(serviceChargeInput);
                if (isNaN(serviceChargeRate) || serviceChargeRate < 0 || serviceChargeRate > 100) {
                    Notification.error('يرجى إدخال معدل رسوم خدمة صحيح (0-100)');
                    return;
                }
            }
            
            // حفظ القيم (null إذا كانت فارغة)
            const taxSettings = {
                taxRate: taxRate,
                serviceChargeRate: serviceChargeRate,
                taxId: taxIdInput || ''
            };
            
            localStorage.setItem('taxServiceSettings', JSON.stringify(taxSettings));
            
            Notification.success('تم حفظ إعدادات الضرائب ورسوم الخدمة بنجاح!');
        }
        
        function resetTaxSettings() {
            if (!confirm('هل تريد إعادة تعيين إعدادات الضرائب ورسوم الخدمة إلى القيم الافتراضية؟')) {
                return;
            }
            
            // إعادة تعيين الحقول إلى فارغة
            document.getElementById('taxRateInput').value = '';
            document.getElementById('serviceChargeInput').value = '';
            document.getElementById('taxIdInput').value = '';
            
            // حذف الإعدادات المحفوظة (ليستخدم النظام القيم الافتراضية)
            localStorage.removeItem('taxServiceSettings');
            
            Notification.success('تم إعادة تعيين إعدادات الضرائب ورسوم الخدمة');
        }
        
