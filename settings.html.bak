        function saveOtherSettings() {
            const settings = {
                taxRate: parseFloat(document.getElementById('taxRate').value),
                currency: document.getElementById('currency').value,
                language: document.getElementById('language').value
            };
            
            const localId = `local_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
            settings._localId = localId;
            settings._synced = false;
            
            localStorage.setItem('appSettings', JSON.stringify(settings));
            
            // إضافة للمزامنة مع Firebase
            if (typeof window !== 'undefined' && window.SyncManager) {
                window.SyncManager.addToSyncQueue('settings', 'update', settings, localId);
            }
            
            Notification.success('تم حفظ الإعدادات بنجاح!');
        }
        
        // Load subscription status on page load
        document.addEventListener('DOMContentLoaded', async () => {
            await loadSubscriptionStatus();
        });
        
        // Load subscription status
        async function loadSubscriptionStatus() {
            try {
                const licenseInfo = JSON.parse(localStorage.getItem('solo_license_info') || 'null');
                const statusEl = document.getElementById('sub-status');
                const expiryEl = document.getElementById('sub-expiry');

                if (!licenseInfo || !licenseInfo.isActivated) {
                    if (statusEl) {
                        statusEl.textContent = 'غير مفعل';
                        statusEl.style.color = '#e74c3c';
                        statusEl.parentElement.style.borderColor = '#e74c3c';
                    }
                    if (expiryEl) expiryEl.textContent = '-';
                    return;
                }

                const now = new Date();
                const expiryDate = new Date(licenseInfo.expiryDate);
                const gracePeriodInMs = 30 * 24 * 60 * 60 * 1000;
                const finalExpiryDate = new Date(expiryDate.getTime() + gracePeriodInMs);

                // Always display the original expiry date
                if (expiryEl && licenseInfo.expiryDate) {
                    const formattedDate = expiryDate.toLocaleDateString('ar-EG', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    });
                    expiryEl.textContent = formattedDate;
                }

                if (now < expiryDate) {
                    // License is active and not expired
                    statusEl.textContent = 'نشط';
                    statusEl.style.color = '#27AE60';
                    statusEl.parentElement.style.borderColor = '#27AE60';
                } else if (now < finalExpiryDate) {
                    // License is expired but within the grace period
                    statusEl.textContent = 'فترة سماح';
                    statusEl.style.color = '#f39c12'; // Orange
                    statusEl.parentElement.style.borderColor = '#f39c12';
                } else {
                    // License and grace period have expired
                    statusEl.textContent = 'غير نشط';
                    statusEl.style.color = '#e74c3c';
                    statusEl.parentElement.style.borderColor = '#e74c3c';
                }

            } catch (error) {
                console.error('Error loading subscription status:', error);
                const statusEl = document.getElementById('sub-status');
                const expiryEl = document.getElementById('sub-expiry');
                if (statusEl) statusEl.textContent = 'خطأ في التحميل';
                if (expiryEl) expiryEl.textContent = '-';
            }
        }
        
        // Handle license activation
        window.handleActivateLicense = async function() {
            const licenseInput = document.getElementById('license-input');
            const activateBtn = document.getElementById('btn-activate-license');
            
            if (!licenseInput || !activateBtn) return;
            
            const licenseCode = licenseInput.value.trim();
            
            if (!licenseCode) {
                if (typeof Notification !== 'undefined') {
                    Notification.error('يرجى إدخال كود الترخيص');
                } else {
                    alert('يرجى إدخال كود الترخيص');
                }
                return;
            }
            
            // Disable button
            activateBtn.disabled = true;
            activateBtn.style.opacity = '0.6';
            activateBtn.style.cursor = 'not-allowed';
            activateBtn.textContent = 'جاري التفعيل...';
            
            try {
                // Call validateLicense function
                if (typeof window.validateLicense === 'function') {
                    const result = await window.validateLicense(licenseCode);
                    
                    if (result.success) {
                        // Show success message
                        if (typeof Notification !== 'undefined') {
                            Notification.success(result.message);
                        } else {
                            alert(result.message);
                        }
                        
                        // Clear input
                        licenseInput.value = '';
                        
                        // Reload subscription status
                        await loadSubscriptionStatus();
                    } else {
                        // Show error message
                        if (typeof Notification !== 'undefined') {
                            Notification.error(result.message);
                        } else {
                            alert(result.message);
                        }
                    }
                } else {
                    throw new Error('دالة validateLicense غير متاحة');
                }
            } catch (error) {
                console.error('Error activating license:', error);
                if (typeof Notification !== 'undefined') {
                    Notification.error('حدث خطأ أثناء التفعيل: ' + error.message);
                } else {
                    alert('حدث خطأ أثناء التفعيل: ' + error.message);
                }
            } finally {
                // Re-enable button
                activateBtn.disabled = false;
                activateBtn.style.opacity = '1';
                activateBtn.style.cursor = 'pointer';
                activateBtn.innerHTML = '<i class=\"fas fa-key\" style=\"margin-left: 8px;\"></i> تفعيل';
            }
        };
        
        // Clear IndexedDB if it exists
        async function clearIndexedDB() {
            return new Promise((resolve, reject) => {
                if (!window.indexedDB) {
                    resolve();
                    return;
                }
                
                // Get all database names
                const databases = [];
                if (indexedDB.databases) {
                    indexedDB.databases().then(dbs => {
                        dbs.forEach(db => {
                            databases.push(db.name);
                        });
                        
                        // Delete each database
                        const deletePromises = databases.map(dbName => {
                            return new Promise((res, rej) => {
                                const deleteRequest = indexedDB.deleteDatabase(dbName);
                                deleteRequest.onsuccess = () => res();
                                deleteRequest.onerror = () => rej(deleteRequest.error);
                                deleteRequest.onblocked = () => {
                                    console.warn(`Database ${dbName} is blocked`);
                                    res(); // Continue even if blocked
                                };
                            });
                        });
                        
                        Promise.all(deletePromises)
                            .then(() => resolve())
                            .catch(err => {
                                console.warn('Error deleting IndexedDB:', err);
                                resolve(); // Continue even if there's an error
                            });
                    }).catch(err => {
                        console.warn('Error getting databases:', err);
                        resolve(); // Continue even if there's an error
                    });
                } else {
                    // Fallback: try to delete common Firebase database names
                    const commonNames = ['firebaseLocalStorageDb', 'firestore'];
                    const deletePromises = commonNames.map(dbName => {
                        return new Promise((res) => {
                            const deleteRequest = indexedDB.deleteDatabase(dbName);
                            deleteRequest.onsuccess = () => res();
                            deleteRequest.onerror = () => res(); // Continue on error
                            deleteRequest.onblocked = () => res(); // Continue if blocked
                        });
                    });
                    
                    Promise.all(deletePromises)
                        .then(() => resolve())
                        .catch(() => resolve()); // Always resolve
                }
            });
        }
        
        // Perform Factory Reset
        async function performFactoryReset() {
            // First confirmation
            const confirm1 = confirm(
                '⚠️ تحذير: هذا الإجراء سيقوم بحذف جميع البيانات!\\n\\n' +
                'سيتم حذف:\\n' +
                '• جميع البيانات المحلية (localStorage)\\n' +
                '• جميع البيانات من Firebase (الطلبات / المصاريف / المخزون / المطبخ / الفئات / الموظفين / الموردين / الشيفتات)\\n' +
                '• قاعدة بيانات IndexedDB\\n\\n' +
                'هذا الإجراء لا يمكن التراجع عنه!\\n\\n' +
                'هل أنت متأكد تماماً؟'
            );
            
            if (!confirm1) {
                return;
            }
            
            // Second confirmation (extra safety)
            const confirm2 = confirm(
                '⚠️ تحذير نهائي!\\n\\n' +
                'أنت على وشك حذف جميع البيانات بشكل نهائي.\\n' +
                'لا يمكن التراجع عن هذا الإجراء.\\n\\n' +
                'هل أنت متأكد 100%؟'
            );
            
            if (!confirm2) {
                return;
            }
            
            // Third confirmation (prompt() not supported in Electron; use confirm instead)
            const confirm3 = confirm(
                '⚠️ تحذير نهائي جداً!\\n\\n' +
                'اضغط \"موافق\" لحذف جميع البيانات نهائياً.\\n' +
                'لا يمكن التراجع عن هذا الإجراء.\\n\\n' +
                'هل تريد المتابعة؟'
            );
            
            if (!confirm3) {
                if (typeof Notification !== 'undefined') {
                    Notification.error('تم إلغاء العملية.');
                } else {
                    alert('تم إلغاء العملية.');
                }
                return;
            }
            
            try {
                // Show loading notification
                if (typeof Notification !== 'undefined') {
                    Notification.info('جاري حذف جميع البيانات... قد تستغرق العملية بضع لحظات.');
                }
                
                // Step 1: Clear Firebase data first
                if (
                    typeof window !== 'undefined' &&
                    window.FirestoreService &&
                    typeof window.FirestoreService.factoryResetFirebase === 'function' &&
                    navigator.onLine
                ) {
                    console.log('Clearing Firebase data...');
                    try {
                        const results = await window.FirestoreService.factoryResetFirebase();
                        console.log('Firebase deletion results:', results);
                    } catch (error) {
                        console.error('Error clearing Firebase:', error);
                        // Continue even if Firebase deletion fails
                    }
                } else {
                    console.warn('Firebase not available or offline - skipping Firebase deletion');
                }
                
                // Step 2: Clear localStorage
                console.log('Clearing localStorage...');
                localStorage.clear();
                
                // Step 3: Clear IndexedDB
                console.log('Clearing IndexedDB...');
                await clearIndexedDB();
                
                // Step 4: Reload the page
                if (typeof Notification !== 'undefined') {
                    Notification.success('تم حذف جميع البيانات بنجاح! جاري إعادة تحميل الصفحة...');
                }
                
                // Wait a moment before reloading to show the notification
                setTimeout(() => {
                    window.location.reload();
                }, 1500);
                
            } catch (error) {
                console.error('Error during factory reset:', error);
                if (typeof Notification !== 'undefined') {
                    Notification.error('حدث خطأ أثناء حذف البيانات: ' + error.message);
                } else {
                    alert('حدث خطأ أثناء حذف البيانات: ' + error.message);
                }
            }
        }
        
// ============================================================ 
// دالة مسح البيانات التشغيلية فقط (تعمل أوفلاين وأونلاين بشكل سليم) 
// ============================================================ 
async function clearOperationalDataOnly() { 
    // 1. رسالة تأكيد قوية 
    const confirmReset = confirm('⚠️ تأكيد مسح البيانات التشغيلية\\n\\nسيتم حذف البيانات التالية فقط:\\n📊 جميع الأوردرات (والمبيعات)\\n💸 جميع المصاريف (وتاريخها)\\n👥 سجل الحضور والانصراف\\n🔄 بيانات الشيفتات واليومية\\n\\nلن يتم حذف:\\n🍔 المنيو والفئات\\n📦 المخزون والخامات\\n👥 الموردين\\n⚙️ الإعدادات والمستخدمين\\n\\nهل تريد المتابعة؟'); 
    
    if (!confirmReset) { 
        return; 
    } 

    const btn = document.querySelector('button[onclick=\"clearOperationalDataOnly()\"]') || event.target; 
    const originalText = btn.innerHTML; 
    btn.innerHTML = '<i class=\"fas fa-spinner fa-spin\"></i> جاري الحذف الجذري...'; 
    btn.disabled = true; 

    try { 
        // 2. تحديد الجداول التشغيلية فقط 
        const operationalCollections = [ 
            'orders',           // الأوردرات 
            'salesHistory',     // تاريخ المبيعات 
            'expenses',         // المصاريف 
            'expensesHistory',  // تاريخ المصاريف 
            'attendance',       // سجل الحضور 
            'cashSessions',     // الشيفتات محلياً 
            'shifts',           // الشيفتات في الفايربيز 
            'daily_log'         // اليومية 
        ]; 

        // 3. مسح البيانات من LocalStorage 
        operationalCollections.forEach(key => { 
            localStorage.removeItem(key); 
            // تفريغ المصفوفة عشان الشاشة متضربش 
            localStorage.setItem(key, JSON.stringify([])); 
        }); 

        // 4. تنظيف طابور المزامنة (عشان السيستم ميرفعش أوردرات قديمة كانت معلقة) 
        let syncQueue = JSON.parse(localStorage.getItem('_syncQueue') || '[]'); 
        syncQueue = syncQueue.filter(item => !operationalCollections.includes(item.collection)); 
        localStorage.setItem('_syncQueue', JSON.stringify(syncQueue)); 
        if (typeof window.SyncManager !== 'undefined') { 
            window.SyncManager.syncQueue = syncQueue; 
        } 

        // 5. المسح الشامل من Firebase (إذا كان متصلاً بالإنترنت) 
        if (navigator.onLine && window.FirestoreService && window.FirestoreService.clearCollection) { 
            console.log('🔄 جاري مسح البيانات التشغيلية من Firebase...'); 
            
            // استخدام دالة clearCollection الاحترافية الموجودة في فايربيز 
            const firebaseCollections = ['orders', 'salesHistory', 'expenses', 'expensesHistory', 'attendance', 'shifts', 'daily_log']; 
            
            for (const col of firebaseCollections) { 
                try { 
                    await window.FirestoreService.clearCollection(col); 
                    console.log(`✅ تم مسح ${col} من الفايربيز بنجاح`); 
                } catch (e) { 
                    console.error(`❌ لم يتم مسح ${col}:`, e); 
                } 
            } 
        } 

        // 6. رسالة النجاح 
        if (typeof Notification !== 'undefined') { 
            Notification.success('✅ تم مسح البيانات التشغيلية بنجاح من الجهاز والسيرفر'); 
        } else { 
            alert('✅ تم مسح البيانات التشغيلية بنجاح من الجهاز والسيرفر'); 
        } 

        // 7. إعادة تحميل الصفحة بعد ثانية ونص 
        setTimeout(() => { 
            window.location.reload(); 
        }, 1500); 

    } catch (error) { 
        console.error('❌ خطأ عام أثناء الحذف:', error); 
        if (typeof Notification !== 'undefined') { 
            Notification.error('❌ حدث خطأ أثناء مسح البيانات'); 
        } else { 
            alert('❌ حدث خطأ أثناء مسح البيانات'); 
        } 
        btn.innerHTML = originalText; 
        btn.disabled = false; 
    } 
}
    
    // Telegram Settings & Accordion Logic
    document.addEventListener('DOMContentLoaded', function () {
        // --- Accordion Logic ---
        // This will handle all accordions on the page
        const accordionHeaders = document.querySelectorAll('.accordion-header');
        accordionHeaders.forEach(header => {
            header.addEventListener('click', () => {
                const accordion = header.parentElement;
                const content = header.nextElementSibling;

                // Toggle active class for animation
                accordion.classList.toggle('active');

                // Toggle icon
                const accordionIcon = header.querySelector('.accordion-icon');
                if (accordion.classList.contains('active')) {
                    content.style.maxHeight = content.scrollHeight + "px";
                    content.style.padding = "var(--spacing-md)";
                } else {
                    content.style.maxHeight = "0";
                    content.style.padding = "0 var(--spacing-md)";
                }
            });
        });

        // --- Telegram Specific Logic ---
        // Check if the Telegram card is on the page before running its logic
        if (document.getElementById('telegramChatId')) {
            loadTelegramSettings();
        }
    });

    async function loadTelegramSettings() {
        const chatId = await DataManager.getSetting('telegramChatId');
        const chatIdInput = document.getElementById('telegramChatId');
        const statusBadge = document.getElementById('telegramStatusBadge');

        if (chatId) {
            chatIdInput.value = chatId;
            statusBadge.textContent = 'متصل';
            statusBadge.classList.remove('badge-gray');
            statusBadge.classList.add('badge-green');
        } else {
            statusBadge.textContent = 'غير نشط';
            statusBadge.classList.remove('badge-green');
            statusBadge.classList.add('badge-gray');
        }
    }

    async function saveTelegramSettings() {
        const saveBtn = document.getElementById('saveTelegramBtn');
        const btnText = saveBtn.querySelector('.btn-text');
        const btnLoader = saveBtn.querySelector('.btn-loader');
        const chatIdInput = document.getElementById('telegramChatId');
        const chatId = chatIdInput.value.trim();

        if (!chatId) {
            showToast('الرجاء إدخال Chat ID صحيح.', 'error');
            return;
        }

        // Show loader and disable button
        btnText.style.display = 'none';
        btnLoader.style.display = 'block';
        saveBtn.disabled = true;

        try {
            await DataManager.saveSetting('telegramChatId', chatId);
            showToast('تم حفظ الإعدادات بنجاح!', 'success');
            // Update status badge after saving
            const statusBadge = document.getElementById('telegramStatusBadge');
            statusBadge.textContent = 'متصل';
            statusBadge.classList.remove('badge-gray');
            statusBadge.classList.add('badge-green');
        } catch (error) {
            console.error("Error saving Telegram Chat ID: ", error);
            showToast('حدث خطأ أثناء حفظ الإعدادات.', 'error');
        } finally {
            // Hide loader and enable button
            setTimeout(() => {
                btnText.style.display = 'inline';
                btnLoader.style.display = 'none';
                saveBtn.disabled = false;
            }, 1000); // Keep loader for a second for better UX
        }
    }

    // You can replace this with your actual toast notification implementation
        function showToast(message, type = 'info') {
            // This is a placeholder. You might have a more sophisticated toast system.
            console.log(`Toast: [${type}] ${message}`);
            alert(message);
        }

        // --- Aggregators Logic ---
        let editingAggregatorId = null;

        function openAggregatorModal() {
            editingAggregatorId = null;
            document.getElementById('aggregatorModalTitle').textContent = 'إضافة شركة توصيل';
            document.getElementById('aggregatorForm').reset();
            document.getElementById('aggregatorId').value = '';
            document.getElementById('aggregatorModal').classList.add('active');
        }

        function closeAggregatorModal() {
            document.getElementById('aggregatorModal').classList.remove('active');
        }

        async function loadAggregators() {
            const aggregatorsList = document.getElementById('aggregatorsList');
            if (!aggregatorsList) return;

            aggregatorsList.innerHTML = `<div class="spinner\" style=\"width: 48px; height: 48px; border: 4px solid #f0f0f0; border-top-color: #000000; border-radius: 50%; margin: 0 auto var(--spacing-md); animation: spin 1s linear infinite;\"></div>`;

            try {
                const aggregators = await window.DataManager.getAggregators();
                aggregatorsList.innerHTML = '';
                if (aggregators.length === 0) {
                    aggregatorsList.innerHTML = `<p>لا توجد شركات توصيل مضافة حالياً.</p>`;
                    return;
                }

                aggregators.forEach(aggregator => {
                    const card = document.createElement('div');
                    card.className = 'user-card'; // Using user-card style for consistency
                    card.innerHTML = `
                        <div class="user-card-header">
                            <div class="user-info">
                                <div class="user-name">${aggregator.companyName}</div>
                            </div>
                        </div>
                        <div class="cashier-stats">
                            <div class="stat-item">
                                <div class="stat-value">${aggregator.commissionPercentage}%</div>
                                <div class="stat-label">العمولة</div>
                            </div>

                        </div>
                        <div class="user-actions">
                            <button class="btn-icon" data-tooltip="تعديل" onclick="editAggregator('${aggregator.id}')">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-icon" data-tooltip="حذف" onclick="deleteAggregator('${aggregator.id}')" style="color: #e74c3c;">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    `;
                    aggregatorsList.appendChild(card);
                });
            } catch (error) {
                console.error('Error loading aggregators:', error);
                aggregatorsList.innerHTML = `<p>حدث خطأ أثناء تحميل البيانات.</p>`;
            }
        }

        async function editAggregator(id) {
            try {
                const aggregators = await window.DataManager.getAggregators();
                const aggregator = aggregators.find(a => a.id === id);
                if (aggregator) {
                    editingAggregatorId = id;
                    document.getElementById('aggregatorModalTitle').textContent = 'تعديل شركة توصيل';
                    document.getElementById('aggregatorId').value = id;
                    document.getElementById('aggregatorName').value = aggregator.companyName;
                    document.getElementById('aggregatorCommission').value = aggregator.commissionPercentage;
                    // document.getElementById('aggregatorMarkup').value = aggregator.menuMarkupPercentage;
                    document.getElementById('aggregatorModal').classList.add('active');
                }
            } catch (error) {
                console.error('Error fetching aggregator for editing:', error);
            }
        }

        async function deleteAggregator(id) {
            if (confirm('هل أنت متأكد من حذف هذه الشركة؟')) {
                try {
                    await window.DataManager.removeAggregator(id);
                    Notification.success('تم حذف الشركة بنجاح');
                    loadAggregators();
                } catch (error) {
                    console.error('Error deleting aggregator:', error);
                    Notification.error('حدث خطأ أثناء الحذف');
                }
            }
        }

        document.getElementById('aggregatorForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const id = document.getElementById('aggregatorId').value;
            const companyName = document.getElementById('aggregatorName').value;
            const commissionPercentage = parseFloat(document.getElementById('aggregatorCommission').value);

            const data = { companyName, commissionPercentage };

            try {
                if (id) {
                    data.id = id;
                }
                await window.DataManager.saveAggregator(data);
                Notification.success(id ? 'تم تحديث الشركة بنجاح' : 'تمت إضافة الشركة بنجاح');
                closeAggregatorModal();
                loadAggregators();
            } catch (error) {
                console.error('Error saving aggregator:', error);
                Notification.error('حدث خطأ أثناء الحفظ');
            }
        });

    </script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-firestore-compat.js"></script>

    <script src="js/firebase-config.js"></script>
    <script src="js/firebase.js"></script>

    <script src="activation.js"></script>
    <script src="js/firestore_service.js"></script>
    <script src="js/sync_manager.js"></script>
    <script src="js/data.js"></script>
    <script src="js/utils.js"></script>
    <script src="js/auth.js"></script>
    <script src="js/notifications.js"></script>
</body>
</html>
