                        <!-- Activate Button -->
                        <button type="button" class="btn btn-primary" id="btn-activate-license" onclick="handleActivateLicense()" style="width: 100%; padding: 18px 32px; font-weight: 800; font-size: 18px; border-radius: 12px; background: linear-gradient(135deg, #000000 0%, #333333 100%); border: none; box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2); transition: all 0.3s ease;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(0, 0, 0, 0.3)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 16px rgba(0, 0, 0, 0.2)';">
                            <i class="fas fa-check-circle" style="margin-left: 10px; font-size: 20px;"></i>
                            تفعيل الترخيص
                        </button>
                    </div>

                    <!-- Telegram Bot Settings Card Removed -->
