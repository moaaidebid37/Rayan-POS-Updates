<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>فحص الطلبات</title>
    <style>
        body {
            font-family: 'Cairo', Arial, sans-serif;
            padding: 20px;
            background: #f5f5f5;
        }
        .container {
            background: white;
            padding: 30px;
            border-radius: 12px;
            max-width: 800px;
            margin: 0 auto;
        }
        h1 { color: #e74c3c; }
        .info {
            background: #e3f2fd;
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
        }
        .order-item {
            background: #f9f9f9;
            padding: 10px;
            margin: 5px 0;
            border-radius: 6px;
            border-right: 3px solid #3498db;
        }
        button {
            background: #e74c3c;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            cursor: pointer;
            margin: 10px 5px;
        }
        button:hover { background: #c0392b; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🔍 فحص مصدر الطلبات</h1>
        <div id="results"></div>
        <button onclick="checkOrders()">فحص الطلبات</button>
        <button onclick="clearAll()" style="background: #c0392b;">مسح جميع الطلبات</button>
    </div>

    <script>
        function checkOrders() {
            const results = document.getElementById('results');
            results.innerHTML = '<p>جاري الفحص...</p>';

            // فحص localStorage
            const localOrders = JSON.parse(localStorage.getItem('orders') || '[]');
            const ordersOnHold = JSON.parse(localStorage.getItem('ordersOnHold') || '[]');
            const salesHistory = JSON.parse(localStorage.getItem('salesHistory') || '[]');
            const resumeOrder = localStorage.getItem('resumeOrder');

            let html = `
                <div class="info">
                    <h3>📊 إحصائيات الطلبات:</h3>
                    <ul>
                        <li><strong>الطلبات العادية (orders):</strong> ${localOrders.length} طلب</li>
                        <li><strong>الطلبات المعلقة (ordersOnHold):</strong> ${ordersOnHold.length} طلب</li>
                        <li><strong>تاريخ المبيعات (salesHistory):</strong> ${salesHistory.length} طلب</li>
                        <li><strong>طلب مستأنف (resumeOrder):</strong> ${resumeOrder ? 'موجود' : 'غير موجود'}</li>
                        <li><strong>المجموع الكلي:</strong> ${localOrders.length + ordersOnHold.length + salesHistory.length} طلب</li>
                    </ul>
                </div>
            `;

            // عرض عينة من الطلبات
            if (localOrders.length > 0) {
                html += '<h3>عينة من الطلبات العادية (أول 5):</h3>';
                localOrders.slice(0, 5).forEach(order => {
                    html += `
                        <div class="order-item">
                            <strong>ID:</strong> ${order.id || 'N/A'}<br>
                            <strong>التاريخ:</strong> ${order.date || 'N/A'}<br>
                            <strong>عدد المنتجات:</strong> ${(order.items || []).length}<br>
                            <strong>الإجمالي:</strong> ${order.total || 0} ج.م
                        </div>
                    `;
                });
            }

            // فحص Firebase
            if (typeof window !== 'undefined' && window.FirestoreService) {
                html += '<div class="info"><strong>Firebase:</strong> متاح - قد يكون هناك طلبات إضافية من Firebase</div>';
            } else {
                html += '<div class="info"><strong>Firebase:</strong> غير متاح - الطلبات من localStorage فقط</div>';
            }

            results.innerHTML = html;
        }

        function clearAll() {
            if (!confirm('هل أنت متأكد من مسح جميع الطلبات؟')) return;

            ['orders', 'ordersOnHold', 'salesHistory', 'resumeOrder'].forEach(key => {
                localStorage.removeItem(key);
                if (key !== 'resumeOrder') {
                    localStorage.setItem(key, JSON.stringify([]));
                }
            });

            alert('✅ تم مسح جميع الطلبات!');
            checkOrders();
        }

        // فحص تلقائي عند التحميل
        window.addEventListener('load', checkOrders);
    </script>
</body>
</html>
